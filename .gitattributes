# Normalize line endings across all platforms.
# Text files are stored with LF in the repo and checked out with LF everywhere.
* text=auto eol=lf

# Explicitly mark binary assets so they are never line-ending converted.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Windows-only scripts keep CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
